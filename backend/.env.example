# Server
PORT=4000
NODE_ENV=development

# MongoDB Atlas (replace with your connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nextgen_logistics?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-in-prod

# Frontend dev origin
CORS_ORIGIN=http://localhost:5173

# Google Maps Platform (Required for location autocomplete)
GOOGLE_MAPS_API_KEY=your_actual_api_key_here

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Driver Event Tracking
SPEED_LIMIT_KMPH=80
HARSH_TURN_DEG=45
HARSH_TURN_WINDOW_SEC=2
IDLE_WINDOW_SEC=300
DRIVER_EVENT_COOLDOWN_SEC=60
